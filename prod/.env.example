# ======================================
# WisdomChurch Infrastructure Configuration
# ======================================
# Copy this file to .env.prod and fill in your actual values

# ACME/SSL Configuration
ACME_EMAIL=your-email@example.com

# Domain Configuration
FRONTEND_DOMAIN=wisdomchurchhq.org
ADMIN_DOMAIN=admin.wisdomchurchhq.org
API_DOMAIN=api.wisdomchurchhq.org

# Image Tags (from Docker registry)
FRONTEND_TAG=main
ADMIN_TAG=main
API_TAG=main

# Service Ports (internal)
FRONTEND_PORT=2000
ADMIN_PORT=3000
API_PORT=8080

# Environment
GIN_MODE=release
ENVIRONMENT=production
LOG_LEVEL=info

# Application Info
APP_NAME=Wisdom Church Support
APP_VERSION=1.0.0
APP_DEBUG=false
APP_SUPPORT_EMAIL=support@wisdomchurchhq.org

# Public URLs
APP_PUBLIC_URL=https://wisdomchurchhq.org
APP_ADMIN_PORTAL_URL=https://admin.wisdomchurchhq.org
APP_FRONTEND_URL=https://wisdomchurchhq.org

# API Configuration
NEXT_PUBLIC_API_URL=https://api.wisdomchurchhq.org
NEXT_PUBLIC_BACKEND_URL=https://api.wisdomchurchhq.org
NEXT_PUBLIC_API_BASE_URL=https://api.wisdomchurchhq.org
API_PROXY_ORIGIN=http://wisdom_api:8080

# CORS Configuration
CORS_ALLOW_ORIGIN=https://admin.wisdomchurchhq.org,https://wisdomchurchhq.org,https://www.wisdomchurchhq.org
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Type,Authorization,Accept,X-Requested-With,X-CSRF-Token
CORS_ALLOW_CREDENTIALS=true
CORS_EXPOSED_HEADERS=Set-Cookie
CORS_MAX_AGE=86400

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require&prefer_simple_protocol=true
MIGRATIONS_DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require&prefer_simple_protocol=true

# Redis Configuration (CRITICAL - must be set)
REDIS_URL=redis://:PASSWORD@redis:6379/0
REDIS_PASSWORD=your-secure-redis-password-here
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_TIMEOUT=4s
REDIS_IDLE_TIMEOUT=5m

# JWT / Authentication
JWT_SECRET=your-jwt-secret-here-min-64-chars-recommended
JWT_EXPIRATION=24h
AUTH_SESSION_IDLE_TIMEOUT=30m
AUTH_REMEMBERED_SESSION_IDLE_TIMEOUT=720h
AUTH_REMEMBER_ME_TTL=720h
AUTH_CSRF_COOKIE_TTL=12h
AUTH_CSRF_COOKIE_NAME=csrf_secret
AUTH_CSRF_HEADER_NAME=X-CSRF-Token
AUTH_SECRET_KEY=your-auth-secret-key-min-64-chars-recommended
AUTH_MFA_ISSUER=Wisdom Church Admin

# Authentication Features
DISABLE_OTP=false
DISABLE_EMAIL=false
DISABLE_LOGIN_OTP=true

# SMTP Configuration
APP_SMTP_HOST=host.docker.internal
APP_SMTP_PORT=25
APP_SMTP_FROM_EMAIL=no-reply@wisdomchurchhq.org
APP_SMTP_FROM_NAME=Wisdom Church
APP_SMTP_TIMEOUT_SECONDS=10
APP_SMTP_TLS=false

# Rate Limiting
RATE_LIMIT_GLOBAL_RPM=1000
RATE_LIMIT_GLOBAL_BURST=300
RATE_LIMIT_GLOBAL_WINDOW=1m

RATE_LIMIT_AUTH_RPM=60
RATE_LIMIT_AUTH_BURST=20
RATE_LIMIT_AUTH_WINDOW=1m

# Storage (S3 / DigitalOcean Spaces)
SPACES_BUCKET=churchasset
SPACES_REGION=fra1
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
SPACES_ACCESS_KEY=your-access-key
SPACES_SECRET_KEY=your-secret-key
SPACES_PUBLIC_BASE_URL=https://churchasset.fra1.digitaloceanspaces.com
SPACES_BASE_PATH=uploads
SPACES_PUBLIC_READ=true
SPACES_EMAIL_TEMPLATE_PATH=email_template

# External Services
NEXT_PUBLIC_CONTACT_PHONE=+2347069995333
YOUTUBE_API_KEY=your-youtube-api-key
NEXT_PUBLIC_YOUTUBE_CHANNEL=@wisdomhousehq
